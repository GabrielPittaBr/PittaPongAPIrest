<%- include('../partials/header') %>

    <main class="container py-4">
        <% if (typeof produto !== 'undefined' && produto) { %>
        <!-- Product Detail -->
        <p class="mb-3"><strong>Raquetes</strong> / <%= produto.nome %></p>
        <div class="row g-4 g-lg-5 mb-5">
            <div class="col-lg-6">
                <div class="imagem-principal d-flex align-items-center justify-content-center">
                    <img src="<%= produto.imagens[0] %>" alt="<%= produto.nome %>" id="imagem-produto-principal">
                </div>
                <div class="galeria-miniaturas d-flex gap-3 mt-3 justify-content-between">
                    <% produto.imagens.forEach((img, index) => { %>
                        <div class="miniatura-item <%= index === 0 ? 'ativa' : '' %>" data-src="<%= img %>" data-alt="<%= produto.nome %> - vista <%= index + 1 %>">
                            <img src="<%= img %>" alt="Miniatura <%= index + 1 %>">
                        </div>
                    <% }) %>
                </div>
            </div>

            <div class="col-lg-6">
                <h1 class="produto-titulo"><%= produto.nome %></h1>
                <p class="produto-preco mb-4">R$ <%= produto.preco.toFixed(2).replace('.', ',') %></p>
                <p class="produto-descricao mb-5">
                    <%= produto.descricao %>
                </p>
                <button class="btn btn-comprar w-100 w-lg-75" onclick="window.location.href='/carrinho'">Adicionar
                    ao carrinho</button>
            </div>
        </div>
        <% } else { %>
            <p class="text-center my-5">Produto não encontrado.</p>
        <% } %>

        <!-- Other Items -->
        <h2 class="text-center fw-semibold mb-4" style="font-size: 2rem;">Outros itens</h2>
        <div class="row g-4 mb-5 justify-content-center">
            <% if (typeof outrosProdutos !== 'undefined' && outrosProdutos && outrosProdutos.length > 0) { %>
                <% outrosProdutos.forEach(outro => { %>
                    <div class="col-6 col-md-3">
                        <div class="produto-card">
                            <div class="produto-img-wrapper">
                                <img src="<%= outro.imagens[0] %>" alt="<%= outro.nome %>">
                            </div>
                            <a href="/produto/<%= outro._id %>">
                                <h3 class="mt-2"><%= outro.nome %></h3>
                            </a>
                            <a href="/produto/<%= outro._id %>">
                                <h4>PittaPong</h4>
                            </a>
                            <a href="/produto/<%= outro._id %>">
                                <p class="preco mt-2">R$ <%= outro.preco.toFixed(2).replace('.', ',') %></p>
                            </a>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <p class="text-center">Nenhum outro produto encontrado.</p>
            <% } %>
        </div>
    </main>

<%- include('../partials/footer') %>