<%- include('../partials/header') %>

    <main class="d-flex align-items-center justify-content-center flex-grow-1 py-5">
        <div class="container" style="max-width: 600px;">
            <h1 class="text-center fw-bold mb-4" style="font-size: 2.5rem;">Login</h1>
            <form action="login.html" method="post">
                <div class="mb-3">
                    <label for="email" class="form-label fw-semibold">Email</label>
                    <input type="email" id="email" name="email" class="form-control form-control-lg" placeholder="Digite seu email" required>
                </div>
                <div class="mb-2">
                    <label for="senha" class="form-label fw-semibold">Senha:</label>
                    <input type="password" id="senha" name="senha" placeholder="Digite sua senha" class="form-control form-control-lg" required>
                </div>
                <p class="esqueci-senha mb-4">Esqueci a senha</p>
                <button type="submit" class="btn btn-login w-100 py-3" onclick="window.location.href='index.html'">Entrar</button>
            </form>
            <p class="texto-cadastro text-center mt-4">Não tem uma conta? <a href="cadastro.html">Cadastre-se</a></p>
        </div>
    </main>

<%- include('../partials/footer') %>