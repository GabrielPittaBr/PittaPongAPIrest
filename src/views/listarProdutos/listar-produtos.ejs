<%- include('../partials/header') %>

    <main class="container py-4">
        <h1 class="fw-bold mb-4" style="font-size: 2.5rem;">
            <%= typeof categoriaAtiva !=='undefined' && categoriaAtiva ? categoriaAtiva : 'Todos os Produtos' %>
        </h1>

        <div class="row g-4">
            <!-- Filters Sidebar -->
            <div class="col-lg-3">
                <div class="filtros p-3">
                    <h2 class="fs-5 pb-2 mb-3">Filtros</h2>

                    <div class="mb-4">
                        <h3 class="fs-6 fw-bold mb-2">Categorias:</h3>
                        <ul class="list-unstyled">
                            <li class="mb-1"><a href="/produtos/listar" class="text-dark">Todos</a></li>
                            <li class="mb-1"><a href="/produtos/listar?categoria=Raquetes"
                                    class="text-dark">Raquetes</a></li>
                            <li class="mb-1"><a href="/produtos/listar?categoria=Bolinhas"
                                    class="text-dark">Bolinhas</a></li>
                            <li class="mb-1"><a href="/produtos/listar?categoria=Redes" class="text-dark">Redes</a></li>
                            <li class="mb-1"><a href="/produtos/listar?categoria=Acessórios"
                                    class="text-dark">Acessórios</a></li>
                            <li class="mb-1"><a href="/produtos/listar?categoria=Outros" class="text-dark">Outros</a>
                            </li>
                        </ul>
                    </div>

                    <div class="mb-4">
                        <h3 class="fs-6 fw-bold mb-2">Faixa de Preço</h3>
                        <input type="range" value="50" class="form-range slider-preco">
                        <p class="small text-muted">R$ 39,99 - R$ 259,99</p>
                    </div>

                    <button class="btn btn-filtrar text-white w-100 fw-semibold">Aplicar Filtros</button>
                </div>
            </div>

            <!-- Product Grid -->
            <div class="col-lg-9">
                <!-- Category Banner -->
                <div class="banner-categoria mb-4">
                    <img src="/img/PittaPongJogadorBanner.png" alt="Banner da categoria">
                    <div class="banner-texto">
                        <h2>
                            <%= typeof categoriaAtiva !=='undefined' && categoriaAtiva
                                ? 'Jogue como um profissional com ' + categoriaAtiva.toLowerCase() + ' da PittaPong.'
                                : 'Confira todos os produtos da PittaPong.' %>
                        </h2>
                    </div>
                </div>

                <div class="row g-3">
                    <% if (typeof produtos !=='undefined' && produtos && produtos.length> 0) { %>
                        <% produtos.forEach(produto=> { %>
                            <div class="col-6 col-md-4">
                                <div class="produto-card">
                                    <div class="produto-img-wrapper">
                                        <img src="<%= produto.imagens[0] %>" alt="<%= produto.nome %>">
                                    </div>
                                    <a href="/produto/<%= produto._id %>">
                                        <h3 class="mt-2">
                                            <%= produto.nome %>
                                        </h3>
                                    </a>
                                    <a href="/produto/<%= produto._id %>">
                                        <h4>PittaPong</h4>
                                    </a>
                                    <a href="/produto/<%= produto._id %>">
                                        <p class="preco mt-2">R$ <%= produto.preco.toFixed(2).replace('.', ',' ) %>
                                        </p>
                                    </a>
                                </div>
                            </div>
                            <% }) %>
                                <% } else { %>
                                    <p class="text-center">Nenhum produto encontrado.</p>
                                    <% } %>
                </div>
            </div>
        </div>
    </main>

    <%- include('../partials/footer') %>