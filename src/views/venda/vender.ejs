<%- include('../partials/header') %>

<main class="container py-4">
    <div class="row">
        <div class="col-md-8">
            <h2 class="mb-4">Crie um Novo Produto</h2>

            <% if (sucesso) { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fa-solid fa-circle-check me-2"></i>
                    Produto cadastrado com sucesso!
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>

            <% if (erro) { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fa-solid fa-circle-exclamation me-2"></i>
                    <strong>Erro:</strong> <%= erro %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            <% } %>

            <form action="/produtos" method="POST" enctype="multipart/form-data">

                <div class="mb-3">
                    <label class="form-label">Nome do Produto</label>
                    <input type="text" name="nome" class="form-control" maxlength="80" required id="input-nome">
                    <div class="d-flex justify-content-end">
                        <small class="text-muted" id="counter-nome">80 caracteres restantes</small>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Preço (R$)</label>
                    <input type="number" name="preco" class="form-control" step="0.01" min="0" required>
                </div>

                <div class="mb-3">
                    <label class="form-label">Categoria</label>
                    <select name="categoria" class="form-select" required>
                        <option value="" disabled selected>Selecione uma categoria</option>
                        <option value="Raquetes">Raquetes</option>
                        <option value="Bolinhas">Bolinhas</option>
                        <option value="Redes">Redes</option>
                        <option value="Acessórios">Acessórios</option>
                        <option value="Outros">Outros</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Descrição</label>
                    <textarea name="descricao" class="form-control" rows="4" maxlength="200" required id="input-descricao"></textarea>
                    <div class="d-flex justify-content-end">
                        <small class="text-muted" id="counter-descricao">200 caracteres restantes</small>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Imagens</label>
                    <input type="file" name="imagens" class="form-control" accept="image/*" multiple id="input-imagens">
                    <small class="text-muted">Até 5 imagens (máx 2MB cada)</small>
                </div>

                <button type="submit" class="btn btn-primary btn-cadastrar-produto">Cadastrar Produto</button>
            </form>
        </div>
    </div>
</main>

<script>
    function setupCounter(inputId, counterId, max) {
        const input = document.getElementById(inputId);
        const counter = document.getElementById(counterId);
        if (!input || !counter) return;

        input.addEventListener('input', () => {
            const restantes = max - input.value.length;
            counter.textContent = `${restantes} caractere${restantes !== 1 ? 's' : ''} restante${restantes !== 1 ? 's' : ''}`;
            counter.classList.toggle('text-danger', restantes <= 10);
            counter.classList.toggle('text-muted', restantes > 10);
        });
    }

    setupCounter('input-nome', 'counter-nome', 80);
    setupCounter('input-descricao', 'counter-descricao', 200);
</script>

<%- include('../partials/footer') %>